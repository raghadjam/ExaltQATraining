		{
			"name": "Fetch Sorted Civils",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"})\r",
							"\r",
							"const response = pm.response.json()\r",
							"const civilID = response.sort((a, b) => Number(b.ID) - Number(a.ID))\r",
							"const civilName = response.map(civil => civil.FirstName + \" \" + civil.LastName).sort()\r",
							"\r",
							"pm.test(\"Sorting based on ID and names\", function () {\r",
							"    pm.expect(civilID[0]).to.be.an('object')\r",
							"    pm.expect(civilID[0].FirstName.toLowerCase()).to.eql(\"maan\")\r",
							"    pm.expect(civilID[0].LastName.toLowerCase()).to.eql(\"ibragheeth\")\r",
							"    pm.expect(civilName[civilName.length - 1].toLowerCase()).to.eql(\"ramzi qaabar\")\r",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
