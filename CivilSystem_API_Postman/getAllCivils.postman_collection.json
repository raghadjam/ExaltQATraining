		{
			"name": "Fetch Civils Phone Number",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"const response = pm.response.json()\r",
							"const ooredoo = [\"george ghawali\", \"alex dukmak\"]\r",
							"const cellcom = [\"maan ibragheeth\"]\r",
							"\r",
							"pm.test(\"Civils with their correct phone prefix\", function () {\r",
							"    response.forEach(civil => {\r",
							"        let number = civil.Mobile.substring(0,3)\r",
							"        let name = civil.FirstName + \" \" + civil.LastName\r",
							"        if(number == \"056\"){\r",
							"            pm.expect(ooredoo).to.include(name)\r",
							"        }\r",
							"        else if (number == \"052\"){\r",
							"            pm.expect(cellcom).to.include(name)\r",
							"        }\r",
							"         else if (number === \"059\") {\r",
							"            pm.expect(ooredoo).to.not.include(name)\r",
							"            pm.expect(cellcom).to.not.include(name)\r",
							"        }\r",
							"        else {\r",
							"            pm.expect.fail(\"Unknown mobile prefix\")\r",
							"        }\r",
							"    })    \r",
							"})"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
